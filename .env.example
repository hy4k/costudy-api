# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# OpenAI API Key (required for embeddings and AI features)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Application Settings
NODE_ENV=production
PORT=8080

# Comma-separated browser origins allowed to call this API (merged with built-in defaults:
# localhost/127.0.0.1:5173, localhost/127.0.0.1:3000, https://costudy.in, https://www.costudy.in)
# Example: CORS_ALLOWED_ORIGINS=https://preview.costudy.in
# CORS_ALLOWED_ORIGINS=

# Embedding and Chat Models
EMBED_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4.1-mini

# Matching thresholds
MATCH_THRESHOLD=0.5
TOPK=10

# Auth & rate limiting (set to false only for local testing without users)
REQUIRE_AI_AUTH=true
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=40
